# Android Configuration

# API for Android Emulator (AVD uses 10.0.2.2 to reach host machine's localhost)
# REACT_APP_API_BASE_URL=http://10.0.2.2:8080/api

# API for Physical Android Device — PC must be on same WiFi as the phone
# Your PC's LAN IP (Ethernet): 192.168.0.3
REACT_APP_DEVICE_IP=http://192.168.0.3:4000/api

# Build identification
REACT_APP_BUILD_TARGET=android
